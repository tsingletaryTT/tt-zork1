# ============================================================================
# PRESET 3: Hybrid Text + Image (2 chips Qwen, 2 chips SDXL)
# ============================================================================
mode: hybrid_image

endpoints:
  # Text tasks on chips 0-1
  translator:
    url: http://localhost:8000/v1/chat/completions
    model: /home/ttuser/models/Qwen3-8B
    chips: [0, 1]       # 2-chip tensor parallel for better quality
    max_tokens: 500
    temperature: 0.1
    prompt_file: prompts/translator/system_v5_with_think.txt

  # Image generation on chips 2-3
  artist:
    url: http://localhost:8100/v1/images/generations  # Different API!
    model: /home/ttuser/models/sdxl-turbo
    chips: [2, 3]       # 2-chip for SDXL
    type: image         # Not text completion!
    prompt_file: prompts/artist/sdxl_zork_style.txt
    output_format: ascii_art_description  # Convert image to ASCII

  # DM also uses the 2-chip Qwen (shared)
  dm:
    url: http://localhost:8000/v1/chat/completions  # Same as translator
    model: /home/ttuser/models/Qwen3-8B
    chips: [0, 1]       # Shares chips with translator
    max_tokens: 500
    temperature: 0.9
    prompt_file: prompts/dm/system_v2_dramatic.txt

  # AI player uses translator endpoint (shared)
  player:
    url: http://localhost:8000/v1/chat/completions
    model: /home/ttuser/models/Qwen3-8B
    chips: [0, 1]       # Shares chips
    max_tokens: 500
    temperature: 0.7
    prompt_file: prompts/player/system_v2_strategic.txt

